{
	"moduleFileExtensions": [
		"js",
		"json",
		"ts"
	],
	"testRegex": ".*\\.spec\\.ts$",
	"transform": {
		"^.+\\.(t|j)s$": "ts-jest"
	},
	"transformIgnorePatterns": [
		"node_modules/(?!(uuid|@discordjs)/)"
	],
	"testEnvironment": "node",
	"coverageDirectory": "./coverage",
	"collectCoverageFrom": [
		"src/**/*.ts"
	]
}
